#!/bin/sh
# Read the Readme for Needed Tools!
export DEPLOYCODE_SILENT_ANSIBLE=1
export DEPLOYCODE_SILENT_INOTIFY=0

# Get Libraries.
# shellcheck source=usr/lib/libDeploy
# Priorize, the Internal Libraries - that's the default.
if [ -f "/usr/lib/libDeploy" ]; then . /usr/lib/libDeploy; else . ./usr/lib/libDeploy; fi
# Priorize, the Development Libs in this folder, that's for Test envirement.
#if [ -r "./usr/lib/libDeploy" ]; then . ./usr/lib/libDeploy; else . /usr/lib/libDeploy; fi

# Search for Playbook Folders..
pb_folder="/etc/deploycode/playbooks/"
[ ! -d "$pb_folder" ] && pb_folder="./etc/deploycode/playbooks"

[ ! -d "$pb_folder" ] && {
	echo "Error! Can not found the Playbook folder. Aborting Script." >&2
	exit 1
}

pb_vars_folder="/etc/deploycode/playbook-vars/"
[ ! -d "$pb_vars_folder" ] && {
	echo "Error! Can not found the Playbook-Vars Folder folder ($pb_vars_folder) folder. Aborting Script." >&2
	exit 1
}

config_folder="/etc/deploycode/configs-enabled"
[ ! -d "$config_folder" ] && {
	echo "Error! Can not found the Config-Enabled folder ($config_folder) folder. Aborting Script." >&2
	exit 1
}

runtime_dir="${DEPLOYCODE_RUNTIME_DIR:-/run/deploycode}"
pb_tmp_pids="$runtime_dir/pids/"
[ ! -d "$pb_tmp_pids" ] && mkdir -p "$pb_tmp_pids"

kill_runnings() {
	for file in "$pb_tmp_pids"/*.pid; do
		[ -f "$file" ] || continue
		pid=$(cat "$file")
		[ -n "$pid" ] || continue

		echo "Stopping watcher PID: $pid"
		pkill -TERM -P "$pid" 2>/dev/null || true
		kill -TERM "$pid" 2>/dev/null || true
		rm -f "$file"
	done
}

ctrl_c() {
	echo "** CTRL-C Pressed. Stop running watchers..."
	kill_runnings
	exit 130
}

terminate() {
	kill_runnings
	exit 143
}

# trap ctrl-c and Termination..
trap ctrl_c INT
trap terminate TERM
trap kill_runnings EXIT

cd "$config_folder" || exit 1
count_configs=$(count_folder_files "$config_folder" "conf" 2>/dev/null || echo 0)
[ "$count_configs" -gt 0 ] || {
	echo "No enabled config files found in $config_folder. Nothing to do." >&2
	exit 1
}

count_run=0
for file in "$config_folder"/*.conf; do
	[ -e "$file" ] || [ -L "$file" ] || continue

	echo Working on: "$file"
	[ -L "$file" ] && {
		file=$(readlink "$file")
		file=$(realpath "$file")
	}
	count_run=$((count_run + 1))
	echo "Starting run $count_run from $count_configs"

	# Its not The Last Config - Start in the Background.
	[ ! "$count_run" = "$count_configs" ] && {
		watch_for_run_pb "$file" &
		watch_pid="$!"
		[ -n "$watch_pid" ] && echo "$watch_pid" >"${pb_tmp_pids}${watch_pid}.pid"
	}

	# Its the Last Config - Start in the Foreground.
	[ "$count_run" = "$count_configs" ] && watch_for_run_pb "$file"
done
