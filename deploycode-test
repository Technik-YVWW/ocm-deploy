#!/bin/sh
export DEPLOYCODE_SILENT_ANSIBLE=0
export DEPLOYCODE_SILENT_INOTIFY=0
export DEPLOYCODE_RUNTIME_DIR="${DEPLOYCODE_RUNTIME_DIR:-/tmp/deploycode-test}"

SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" && pwd)

# Get libraries.
# shellcheck source=usr/lib/libDeploy
# Prioritize the development library for tests.
if [ -r "$SCRIPT_DIR/usr/lib/libDeploy" ]; then
	. "$SCRIPT_DIR/usr/lib/libDeploy"
else
	. /usr/lib/libDeploy
fi

# Search for playbook folders.
pb_folder="/etc/deploycode/playbooks/"
[ -d "$pb_folder" ] || pb_folder="$SCRIPT_DIR/etc/deploycode/playbooks/"

[ -d "$pb_folder" ] || {
	echo "Error! Can not find the playbook folder. Aborting script." >&2
	exit 1
}

pb_vars_folder="/etc/deploycode/playbook-vars/"
[ -d "$pb_vars_folder" ] || pb_vars_folder="$SCRIPT_DIR/etc/deploycode/playbook-vars/"

[ -d "$pb_vars_folder" ] || {
	echo "Error! Can not find the playbook-vars folder ($pb_vars_folder). Aborting script." >&2
	exit 1
}

# The config folder in the test script is configs-available.
config_folder="/etc/deploycode/configs-available"
[ -d "$config_folder" ] || config_folder="$SCRIPT_DIR/etc/deploycode/configs-available"

[ -d "$config_folder" ] || {
	echo "Error! Can not find the configs-available folder ($config_folder). Aborting script." >&2
	exit 1
}

enabled_config_folder="/etc/deploycode/configs-enabled"
[ -d "$enabled_config_folder" ] || enabled_config_folder="$SCRIPT_DIR/etc/deploycode/configs-enabled"
count_configs=$(count_folder_files "$enabled_config_folder" "conf" 2>/dev/null || echo 0)
echo "Activated config files: $count_configs"

# Get the config name to test.
config_name="${1:-}"
[ -n "$config_name" ] || {
	echo "Error: this is a test script. Pass a file name placed in $config_folder as first parameter."
	echo "Listing. Pass it without the .conf suffix:"
	ls "$config_folder"
	echo "Aborting script for this time."
	exit 1
}

config_file="${config_folder}/${config_name}.conf"
[ -f "$config_file" ] || {
	echo "Error! The file $config_file does not exist." >&2
	echo "Aborting script." >&2
	exit 2
}

watch_for_run_pb "$config_file" "" "" "1"
