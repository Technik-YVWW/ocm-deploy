[ "$DEPLOYCODE_SILENT_ANSIBLE" = "" ] && DEPLOYCODE_SILENT_ANSIBLE=0
[ "$DEPLOYCODE_SILENT_INOTIFY" = "" ] && DEPLOYCODE_SILENT_INOTIFY=0

#
# Find Tools for the Scripts: Ansible and inootify(wait)
#

find_tool_inotify() {
    [ -x "$tool_inotifywait" ] && return 0

    tool_inotifywait=$(which inotifywait)
    [ ! -x "$tool_inotifywait" ] && {
        echo "The Inotifywait tool Can not be found. Please install it first"
        exit 0
    }
}

find_tool_ansible() {
    [ -x "$tool_ansible" ] && return 0

    tool_ansible=$(which ansible-playbook)
    [ ! -x "$tool_ansible" ] && {
        echo "The ansible-playbook tool Can not be found. Please install it first"
        exit 0
    }
}

# Count files in a Specified Folder.
count_folder_files() {
    folder="$1"
    extension="$2"
    types="$3"
    [ -z "$folder" ] && return 1
    [ -z "$types" ] && types="f,l"

    [ -z "$extension" ] && counter=$(find "$folder"/* -maxdepth 0 -type "$types") || counter=$(find "$folder"/*."$extension" -maxdepth 0 -type "$types")
    [ -z "$counter" ] && return 2

    counter=$(echo "$counter" | wc -l)
    [ -z "$counter" ] && return 3

    echo "$counter"
    return 0
}

# von einer .conf datei, den wert Extrahieren.
get_config_value()
{
    file_path="$1"
    [ ! -r "$file_path" ] && return 1

    valuename="$2"
    [ -z "$valuename" ] && return 1

    grep -v "^#" "$file_path" | grep -w "$valuename" | awk -F"${valuename}:" '{print $2}' | tr -d '[:space:]'
}

# von einer .xml datei, den wert Extrahieren.
get_yml_value()
{
    file_path="$1"
    [ ! -r "$file_path" ] && return 1

    valuename="$2"
    [ -z "$valuename" ] && return 1

    grep -w  "$valuename" "$file_path" | awk -F':' '{print $2}' | tr -d '[:space:]'
}

# Function to Execute the Ansible Playbook.
run_ansible_playbook() {
    playbook="$1"
    inventory="$2"
    vars_file="$3"

    find_tool_ansible
    for file in $playbook $inventory $vars_file; do
        [ ! -f "$file" ] && {
            echo "Aborting Starting Playbook, file: $file does not exist."
            return 1
        }
    done

    if [ "$DEPLOYCODE_SILENT_ANSIBLE" = "1" ]; then
        $tool_ansible -i "$inventory" -e "@$vars_file" "$playbook" >/dev/null 2>&1
    else
        $tool_ansible -i "$inventory" -e "@$vars_file" "$playbook"
    fi

    return $?
}

#
# Mainfunction of the Library, got immortal use with Inotifywait
#
# $1: Inotifywait Watchfolder
# $2: The Vars file, for run_ansible_playbook ($3)
# $3: The Playbook file, under /usr/lib/libDeploy/playbooks
# $4: Testmode: execute direct and without wait and a Loop.
#
watch_for_run_pb() {
    config_file="$1"
    [ ! -r "$config_file" ] && {
        echo "Can not Read the Config: $config_file. Abort."
        return 1
    }

    playbook_folder="$2"
    # shellcheck disable=SC2154
    [ -z "$playbook_folder" ] && playbook_folder="$pb_folder"
    [ ! -d "$playbook_folder" ] && echo "No Playbook folder found ($playbook_folder) in function watch_and_run_playbooks, abort." && return 2

    playbook_vars_folder="$3"
    # shellcheck disable=SC2154
    [ -z "$playbook_vars_folder" ] && playbook_vars_folder="$pb_vars_folder"
    [ ! -d "$playbook_vars_folder" ] && echo "No Playbook vars folder ($playbook_vars_folder) found in function watch_and_run_playbooks, abort." && return 3

    testmode="$4"
    [ -z "$testmode" ] && testmode="0"

    tmp_inventorys="/tmp/deploycode/inv/"
    [ ! -d "$tmp_inventorys" ] && mkdir -p "$tmp_inventorys"

    # Get the Dir to Watch.
    inotify_watchdir=$(get_config_value "$config_file" "inotify_watchdir")
    [ ! -d "$inotify_watchdir" ] && {
        echo "ERROR: The Directory $inotify_watchdir does not exist. Abort."
        return 1
    }

    while true; do
        # The Watchdir is deleted, so stop the Script .
        [ ! -d "$inotify_watchdir" ] && break

        # Looking for Changes in the Watchdir
        if [ "$testmode" = "0" ]; then
            find_tool_inotify
            #echo Starting inotifywait: inotifywait -r -e modify,create,delete "$inotify_watchdir"

            if [ "$DEPLOYCODE_SILENT_INOTIFY" = "1" ]; then
                $tool_inotifywait -r -e modify,create,delete "$inotify_watchdir" >/dev/null 2>&1
            else
                $tool_inotifywait -r -e modify,create,delete "$inotify_watchdir"
            fi
            retval="$?"

            [ ! "$retval" = "0" ] && {
                echo "Error in Inotifywait, aborting Loop, Directory Deleted??"
                break
            }

            # Waiting 5 Seconds after action. be gentle to the filesystem
            sleep 5
        else
            echo "-- IN TESTMODE: Skipping inotify."
        fi

        for i in $(seq 1 100); do
          playbook_file=$(get_config_value "$config_file" "playbook${i}")
          playbook_vars_file=$(get_config_value "$config_file" "vars_playbook${i}")
          [ -z "$playbook_file" ] && break
          [ -z "$playbook_vars_file" ] && break

          # Building Full Paths..
          playbook_file="${playbook_folder}${playbook_file}.yml"
          [ ! -r "$playbook_file" ] && echo "Error! Playbook File ($playbook_file) does not exist! Abort!" && break

          playbook_vars_file="${playbook_vars_folder}${playbook_vars_file}.yml"
          [ ! -r "$playbook_vars_file" ] && echo "Error! Playbook Vars File ($playbook_vars_file) does not exist! Abort!" && break

          # Creating a Temporary Inventory.
          server=$(get_yml_value "$playbook_vars_file" "target_server")
          [ -z "$server" ] && {
             echo "Can not found a Server. Skript abort."
          }

          playbook_inv_file="${tmp_inventorys}inv_$(echo "$server" | tr -d '.').ini"
          [ ! -f "$playbook_inv_file" ] && {
            touch "$playbook_inv_file"
            echo "[hosts]" >> "$playbook_inv_file"
            echo "$server" >> "$playbook_inv_file"
          }

          echo "Execute Playbook: $playbook_file, vars: $playbook_vars_file, inv: $playbook_inv_file"
          run_ansible_playbook "$playbook_file" "$playbook_inv_file" "$playbook_vars_file"
        done

        # On Testmode: only run one time.
        [ "$testmode" = "1" ] && {
            echo "-- IN TESTMODE: We Not Wait for Changes, Skript is End now."
            break
        }

        [ -f "$playbook_inv_file" ] && rm -f "$playbook_inv_file"
    done
}
